        "subject": "=Invoice Processed Successfully - {{$json.output.invoice_number}}",
        "message": "=<h2>Invoice Processing Report</h2>\n\n<p>Hello {{$node[\"On form submission\"].json[\"Full Name\"]}},</p>\n\n<p>Your invoice has been successfully processed.</p>\n\n<table border=\"1\" cellpadding=\"8\" cellspacing=\"0\">\n<tr>\n<td><b>Invoice Number</b></td>\n<td>{{$node[\"Basic LLM Chain\"].json.output.invoice_number}}</td>\n</tr>\n\n<tr>\n<td><b>Vendor</b></td>\n<td>{{$node[\"Basic LLM Chain\"].json.output.vendor}}</td>\n</tr>\n\n<tr>\n<td><b>Invoice Date</b></td>\n<td>{{$node[\"Basic LLM Chain\"].json.output.invoice_date}}</td>\n</tr>\n\n<tr>\n<td><b>Due Date</b></td>\n<td>{{$node[\"Basic LLM Chain\"].json.output.due_date}}</td>\n</tr>\n\n<tr>\n<td><b>Amount</b></td>\n<td>{{$node[\"Basic LLM Chain\"].json.output.amount}} {{$node[\"Basic LLM Chain\"].json.output.currency}}</td>\n</tr>\n\n<tr>\n<td><b>Tax</b></td>\n<td>{{$node[\"Basic LLM Chain\"].json.output.tax}}</td>\n</tr>\n\n<tr>\n<td><b>Category</b></td>\n<td>{{$node[\"Basic LLM Chain\"].json.output.category}}</td>\n</tr>\n\n<tr>\n<td><b>Payment Status</b></td>\n<td>{{$node[\"Basic LLM Chain\"].json.output.payment_status}}</td>\n</tr>\n\n<tr>\n<td><b>Confidence Score</b></td>\n<td>{{$node[\"Basic LLM Chain\"].json.output.confidence_score}}%</td>\n</tr>\n\n<tr>\n<td><b>Risk Level</b></td>\n<td>{{$node[\"Basic LLM Chain\"].json.output.risk_level}}</td>\n</tr>\n</table>\n\n<h3>Summary</h3>\n\n<p>{{$node[\"Basic LLM Chain\"].json.output.summary}}</p>\n\n<hr>\n\n<p>\nGenerated automatically by the AI Invoice Processing System.\n</p>",
